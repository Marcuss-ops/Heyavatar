{
  "annotations": { "list": [] },
  "description": "Heyavatar engine: GPU-seconds per minute of output (the headline economic metric), plus queue depth, worker state distribution, render latency, and request latency. Refresh interval 15s to match Prometheus scrape.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU-seconds per minute of output (headline)",
      "description": "Computed ratio: rate(heyavatar_gpu_seconds_total[5m]) / rate(heyavatar_output_minutes_total[5m]). Two Counters \u2014 NEVER computed in Python \u2014 because cross-worker aggregation must do the math in Prometheus.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "GPU-seconds / minute of output",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(heyavatar_gpu_seconds_total[5m])) by (engine_id, tier) / clamp_min(sum(rate(heyavatar_output_minutes_total[5m])) by (engine_id, tier), 0.001)",
          "legendFormat": "{{engine_id}} / {{tier}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GPU-seconds burned (rate per minute)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum(rate(heyavatar_gpu_seconds_total[5m])) by (engine_id)",
          "legendFormat": "{{engine_id}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Output minutes produced (rate per minute)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "m" } },
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum(rate(heyavatar_output_minutes_total[5m])) by (engine_id, tier)",
          "legendFormat": "{{engine_id}} / {{tier}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue depth by backend",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(heyavatar_queue_depth) by (backend, tier)",
          "legendFormat": "{{backend}} / {{tier}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Inflight jobs per engine",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(heyavatar_inflight_jobs) by (engine_id)",
          "legendFormat": "{{engine_id}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Jobs terminal states (rate per second)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(heyavatar_jobs_total[5m])) by (state)",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Render-chunk latency p95 (by engine)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(heyavatar_render_chunk_latency_seconds_bucket[5m])) by (engine_id, le))",
          "legendFormat": "p95 {{engine_id}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP request latency p95 by route",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(heyavatar_request_latency_seconds_bucket[5m])) by (route, le))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["heyavatar", "video", "ai"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Heyavatar Engine Economics",
  "uid": "heyavatar-engine-economics",
  "version": 1,
  "weekStart": ""
}
